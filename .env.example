# ==========================================
# ECHO-CLAW SYSTEM - ENVIRONMENT TEMPLATE
# ==========================================

# ==========================================
# 1. API KEYS
# ==========================================
# Insert your real keys into your local .env file.
# Never commit real API keys to GitHub.

OPENAI_API_KEY=your-openai-key-here
GOOGLE_API_KEY=your-google-ai-studio-key-here

# ==========================================
# 2. MODEL SELECTION
# ==========================================
# Default recommended profile: Google
# Viewer = stronger perceptual engine
# Monitor = lighter support engine

MONITOR_MODEL=gemini-3.1-flash-lite-preview
VIEWER_MODEL=gemini-3.1-pro-preview

# --- Alternative OpenAI profile ---
# To use the GPT profile, remove `#` from the two lines below.
# MONITOR_MODEL=gpt-5.4-mini
# VIEWER_MODEL=gpt-5.4

# ==========================================
# 3. SYSTEM PATHS
# ==========================================
# Base working directories used by the RV system

WORKSPACE_DIR=./workspace
VAULT_DIR=./workspace/vault
KNOWLEDGE_DIR=./workspace/knowledge
LEARNING_DIR=./workspace/learning
SESSIONS_DIR=./workspace/sessions
ARCHIVE_DIR=./workspace/archive
